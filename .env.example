# Marzban panel base URL (no trailing slash)
MARZBAN_URL=https://ze.cyber-x.online:10086

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat IDs that are allowed to control the bot and receive alerts
# Send /whoami to the bot once it's running to get your id, then put it here.
TELEGRAM_ADMIN_CHAT_IDS=

# HTTP API port the forward-VPS daemon will POST alerts to
API_PORT=3000

# Bearer token the forward-VPS daemon must send in `Authorization: Bearer <token>` header
API_TOKEN=change-me-to-a-long-random-string
